Dialogue: 0,0:00:42.51,0:00:47.12,OP11 Credits,,470,0,300,,Quality Checking\NGalaxy 9000\NMr. Luffy
Dialogue: 0,0:00:47.99,0:00:55.00,Lyrics,,0,0,1,,{\i1}Cut through the rainbow-colored wind\Nand head for a sea of adventure{\i}
Dialogue: 0,0:00:55.13,0:00:58.57,Lyrics,,0,0,0,,{\i1}It'll be a journey fraught with injury{\i}
Dialogue: 0,0:00:58.65,0:01:02.30,Lyrics,,0,0,0,,{\i1}but what you cherish most will be right there{\i}
Dialogue: 0,0:01:02.50,0:01:06.47,OP11 Credits,,0,30,410,,Timing\NDatenshi
Dialogue: 0,0:01:02.50,0:01:06.43,Lyrics,,0,0,0,,{\i1}And if you get into a jam{\i}
Dialogue: 0,0:01:06.51,0:01:08.38,Lyrics,,0,0,0,,{\i1}I'll always be there to protect you{\i}
Dialogue: 0,0:01:09.51,0:01:13.36,Lyrics,,0,0,0,,{\i1}It's all right! Now let's move forward{\i}
Dialogue: 0,0:01:13.71,0:01:16.85,Lyrics,,0,0,0,,{\i1}with the sun always in our hearts{\i}
Dialogue: 0,0:01:17.23,0:01:20.35,Lyrics,,0,0,1,,{\i1}If a storm hits, let's put\Nour arms around each other{\i}
Dialogue: 0,0:01:20.46,0:01:24.23,Lyrics,,0,0,0,,{\fad(75,0)}{\i1}and gaze at the light beyond{\i}
Dialogue: 0,0:01:24.72,0:01:27.97,Lyrics,,0,0,0,,{\i1}If we gather up the pieces of our dreams{\i}
Dialogue: 0,0:01:28.46,0:01:31.58,Lyrics,,0,0,0,,{\i1}they'll make a map leading to tomorrow{\i}
Dialogue: 0,0:01:31.73,0:01:34.75,Lyrics,,0,0,0,,{\i1}So let's grab hold of our wishes{\i}
Dialogue: 0,0:01:35.20,0:01:40.48,Lyrics,,0,0,0,,{\i1}under the same flag-- together, we're one{\i}
Dialogue: 0,0:01:51.71,0:01:56.13,Main,,0,0,0,,Avec une détermination incroyable, Chapeau de Paille Luffy se relève encore une fois !
Dialogue: 0,0:01:56.27,0:01:58.96,Main,,0,0,0,,Même après d'innombrables coups, il se relève sans cesse !
Dialogue: 0,0:01:58.96,0:02:00.00,Main,,0,0,0,,Luffy... !
Dialogue: 0,0:02:00.81,0:02:04.41,Main,,0,0,0,,Mais qu'est-ce que tu es ?!
Dialogue: 0,0:02:06.33,0:02:07.98,Main,,0,0,0,,Luffy !
Dialogue: 0,0:02:07.98,0:02:10.04,Main,,0,0,0,,Il est instable sur ses jambes !
Dialogue: 0,0:02:10.04,0:02:11.11,Main,,0,0,0,,Luffy !
Dialogue: 0,0:02:11.45,0:02:13.47,Main,,0,0,0,,Et il est à bout de souffle !
Dialogue: 0,0:02:13.47,0:02:15.03,Main,,0,0,0,,Ce type est incroyable !
Dialogue: 0,0:02:15.77,0:02:17.15,Main,,0,0,0,,Et pourtant...
Dialogue: 0,0:02:17.15,0:02:20.55,Main,,0,0,0,,Il reste debout, une lueur dans les yeux !
Dialogue: 0,0:02:23.37,0:02:25.12,Main,,0,0,0,,Tout ça pour ses amis !
Dialogue: 0,0:02:25.12,0:02:28.16,Main,,0,0,0,,Oui ! Ça, c'est un Davy Back Fight !
Dialogue: 0,0:02:28.16,0:02:32.15,Main,,0,0,0,,J'ai les larmes aux yeux, je... je n'y vois plus rien !
Dialogue: 0,0:02:33.81,0:02:35.61,Main,,0,0,0,,Luffy !
Dialogue: 0,0:02:35.61,0:02:37.48,Main,,0,0,0,,Luffy !!
Dialogue: 0,0:02:37.48,0:02:38.96,Main,,0,0,0,,Je suis ému aux larmes !
Dialogue: 0,0:02:38.96,0:02:41.29,Main,,0,0,0,,Afro, mec !
Dialogue: 0,0:02:41.29,0:02:45.75,Main,,0,0,0,,Luffy ! Luffy ! Luffy !...
Dialogue: 0,0:02:45.75,0:02:48.61,Main,,0,0,0,,Un chant Luffy s'élève de la foule !
Dialogue: 0,0:02:49.13,0:02:54.21,Main,,0,0,0,,Y a-t-il déjà eu un autre adversaire qui ait donné autant de fil à retordre à notre boss ?!
Dialogue: 0,0:02:55.51,0:03:00.67,Main,,0,0,0,,Qu'est-ce que vous faites, idiots, à encourager l'ennemi ?!
Dialogue: 0,0:03:02.85,0:03:04.18,Main,,0,0,0,,Boss... !
Dialogue: 0,0:03:04.18,0:03:05.16,Main,,0,0,0,,Boss !
Dialogue: 0,0:03:05.16,0:03:10.40,Main,,0,0,0,,Boss ! Boss ! Boss ! Boss !
Dialogue: 0,0:03:10.40,0:03:13.31,Main,,0,0,0,,Regardez bien. Je vais en finir maintenant !
Dialogue: 0,0:03:10.45,0:03:15.79,Secondary,,0,0,0,,Boss ! Boss ! Boss ! Boss !
Dialogue: 0,0:03:15.79,0:03:18.71,Main,,0,0,0,,{\fad(150,150)}Épée Slow Beam !
Dialogue: 0,0:03:19.71,0:03:21.35,Main,,0,0,0,,Il va falloir faire mieux que ça !
Dialogue: 0,0:03:23.79,0:03:28.00,Main,,0,0,0,,Mince ! Il n'a plus assez de force pour courir ?!
Dialogue: 0,0:03:28.00,0:03:30.21,Main,,0,0,0,,D'accord ! Il est temps d'en finir !
Dialogue: 0,0:03:30.88,0:03:32.62,Main,,0,0,0,,{\fad(150,150)}Slow Beam !
Dialogue: 0,0:03:32.62,0:03:36.37,Main,,0,0,0,,Notre boss fait le premier pas ! Il commence par ralentir un boulet de canon !
Dialogue: 0,0:03:38.05,0:03:39.83,Main,,0,0,0,,{\fad(150,150)}Foxy Fighter !
Dialogue: 0,0:03:40.99,0:03:43.11,Main,,0,0,0,,Un coup de poing mégatonne à la vitesse d'un boulet de canon !
Dialogue: 0,0:03:43.45,0:03:45.13,Main,,0,0,0,,Ça va t'assommer pour de bon !
Dialogue: 0,0:03:45.99,0:03:49.84,Main,,0,0,0,,Le voilà ! Le vol acrobatique au boulet de canon de notre boss !
Dialogue: 0,0:03:49.84,0:03:52.23,Main,,0,0,0,,Il va porter le coup de grâce à bord du Foxy Fighter !
Dialogue: 0,0:03:53.01,0:03:56.47,Main,,0,0,0,,Luffy ! Il a utilisé un rayon sur toi juste avant le boulet !
Dialogue: 0,0:03:56.83,0:03:59.05,Main,,0,0,0,,Esquive dès que tu peux bouger !
Dialogue: 0,0:04:04.75,0:04:06.02,Main,,0,0,0,,Oh ! Je peux bouger !
Dialogue: 0,0:04:06.02,0:04:09.40,Main,,0,0,0,,Le rayon s'estompe sur Chapeau de Paille juste un instant plus tôt !
Dialogue: 0,0:04:09.95,0:04:10.71,Main,,0,0,0,,C'est inutile !
Dialogue: 0,0:04:11.13,0:04:12.59,Main,,0,0,0,,Il n'y a pas d'échappatoire !
Dialogue: 0,0:04:18.85,0:04:20.89,Main,,0,0,0,,Luffy ! Attention !
Dialogue: 0,0:04:23.41,0:04:25.33,Main,,0,0,0,,Tiens, un cadeau pour toi !
Dialogue: 0,0:04:26.69,0:04:31.06,Main,,0,0,0,,Il l'a eu ! Toutes ses attaques touchent Chapeau de Paille !
Dialogue: 0,0:04:31.06,0:04:35.81,Main,,0,0,0,,Boss ! Boss ! Boss !
Dialogue: 0,0:04:35.81,0:04:38.43,Main,,0,0,0,,Qu'est-ce qu'il lui prend ?! Il n'avait pas besoin d'aller aussi loin !
Dialogue: 0,0:04:45.47,0:04:48.43,Main,,0,0,0,,I-I-Il est... Il est de nouveau debout !
Dialogue: 0,0:04:50.77,0:04:52.05,Main,,0,0,0,,Comment... ?!
Dialogue: 0,0:05:10.65,0:05:13.33,Main,,0,0,0,,J'ai... gagné.
Dialogue: 0,0:05:15.15,0:05:19.59,Main,,0,0,0,,Quoi ?! Tu peux à peine te tenir debout !
Dialogue: 0,0:05:20.30,0:05:24.57,Main,,0,0,0,,Mais si c'est ce que tu veux, je vais te marteler jusqu'à ce que tu restes à terre !
Dialogue: 0,0:05:24.99,0:05:27.54,Main,,0,0,0,,{\fad(150,150)}Mégatonne Neuf Queues... !
Dialogue: 0,0:05:27.54,0:05:29.93,Main,,0,0,0,,{\fad(150,150)}Caoutchouc...
Dialogue: 0,0:05:29.93,0:05:32.42,Main,,0,0,0,,{\fad(150,150)}Ruée !
Dialogue: 0,0:05:32.42,0:05:36.03,Main,,0,0,0,,{\fad(150,150)}Gatling !
Dialogue: 0,0:05:39.89,0:05:41.41,Main,,0,0,0,,Quelle intensité !
Dialogue: 0,0:05:41.41,0:05:45.53,Main,,0,0,0,,Les combattants échangent maintenant une rafale de coups encore plus féroce !
Dialogue: 0,0:05:45.53,0:05:47.95,Main,,0,0,0,,Massacre-le, Luffy !
Dialogue: 0,0:05:47.95,0:05:50.81,Main,,0,0,0,,Leurs barrages ne s'arrêtent pas ! Ils continuent sans cesse !
Dialogue: 0,0:05:56.21,0:05:57.77,Main,,0,0,0,,Luffy !
Dialogue: 0,0:06:01.31,0:06:04.81,Main,,0,0,0,,{\fad(150,150)}Slow Beam !
Dialogue: 0,0:06:07.65,0:06:08.97,Main,,0,0,0,,Oh... ?!
Dialogue: 0,0:06:08.97,0:06:10.28,Main,,0,0,0,,Qu'est-ce que... ?
Dialogue: 0,0:06:10.61,0:06:11.75,Main,,0,0,0,,Il a arrêté de bouger...
Dialogue: 0,0:06:28.07,0:06:30.27,Main,,0,0,0,,S-Chapeau de Paille a été mis à terre !
Dialogue: 0,0:06:30.81,0:06:32.71,Main,,0,0,0,,Non ! Rectification !
Dialogue: 0,0:06:32.71,0:06:34.55,Main,,0,0,0,,C'est Chapeau de Paille qui bouge !
Dialogue: 0,0:06:34.55,0:06:37.12,Main,,0,0,0,,Que s'est-il passé ?!
Dialogue: 0,0:06:37.12,0:06:40.31,Main,,0,0,0,,Maudit... sois-tu...
Dialogue: 0,0:06:40.31,0:06:41.19,Main,,0,0,0,,Comment ?!
Dialogue: 0,0:06:42.35,0:06:43.87,Main,,0,0,0,,Boss ?!
Dialogue: 0,0:06:46.83,0:06:51.12,Main,,0,0,0,,Un miroir ! Un fragment de miroir\Nest tombé de la main de Chapeau de Paille !
Dialogue: 0,0:06:51.12,0:06:55.25,Main,,0,0,0,,Il était coincé... dans mon Afro...
Dialogue: 0,0:06:55.25,0:06:57.64,Main,,0,0,0,,C'est du miroir de ta chambre !
Dialogue: 0,0:06:57.64,0:07:01.04,Main,,0,0,0,,Petit...!
Dialogue: 0,0:07:01.04,0:07:03.35,Main,,0,0,0,,{\fad(150,150)}Caoutchouc...
Dialogue: 0,0:07:10.75,0:07:13.61,Main,,0,0,0,,{\fad(150,150)}Fléau !
Dialogue: 0,0:07:39.03,0:07:40.05,Main,,0,0,0,,Oh non... !
Dialogue: 0,0:07:41.01,0:07:42.36,Main,,0,0,0,,Plus que huit secondes.
Dialogue: 0,0:07:42.36,0:07:42.95,Main,,0,0,0,,Hein ?
Dialogue: 0,0:07:43.59,0:07:44.41,Main,,0,0,0,,Hein ?!
Dialogue: 0,0:07:44.87,0:07:47.57,Main,,0,0,0,,Serait-ce ce que je pense... ?!
Dialogue: 0,0:07:47.89,0:07:49.24,Main,,0,0,0,,Sept.
Dialogue: 0,0:07:49.24,0:07:50.15,Main,,0,0,0,,Quoi ?
Dialogue: 0,0:07:50.83,0:07:51.71,Main,,0,0,0,,Six.
Dialogue: 0,0:07:52.47,0:07:54.44,Main,,0,0,0,,Boss !
Dialogue: 0,0:07:59.87,0:08:00.87,Main,,0,0,0,,Cinq !
Dialogue: 0,0:08:01.43,0:08:05.69,Main,,0,0,0,,Qu'est-ce que vous faites ?! Comptez aussi ! Quatre !
Dialogue: 0,0:08:06.55,0:08:07.36,Main,,0,0,0,,Quoi ?
Dialogue: 0,0:08:07.36,0:08:08.97,Main,,0,0,0,,Je sais pas ! Mais ça a l'air amusant !
Dialogue: 0,0:08:11.95,0:08:13.29,Main,,0,0,0,,Trois !
Dialogue: 0,0:08:13.61,0:08:14.61,Main,,0,0,0,,Deux !
Dialogue: 0,0:08:15.09,0:08:15.99,Main,,0,0,0,,Un !
Dialogue: 0,0:08:16.53,0:08:18.75,Main,,0,0,0,,Zéro !
Dialogue: 0,0:08:29.69,0:08:31.21,Main,,0,0,0,,Hourra !
Dialogue: 0,0:08:32.89,0:08:35.33,Main,,0,0,0,,Boss !
Dialogue: 0,0:08:36.77,0:08:40.04,Main,,0,0,0,,Notre boss est envoyé dans les airs !
Dialogue: 0,0:08:52.59,0:08:54.19,Main,,0,0,0,,Et il atterrit...
Dialogue: 0,0:08:57.28,0:08:59.86,Main,,0,0,0,,...hors du champ de bataille !
Dialogue: 0,0:08:59.86,0:09:01.74,Main,,0,0,0,,Le dernier round de combat du Davy Back Fight
Dialogue: 0,0:09:01.74,0:09:04.95,Main,,0,0,0,,s'est terminé après une bataille épique et acharnée entre les deux Capitaine !
Dialogue: 0,0:09:05.27,0:09:09.14,Main,,0,0,0,,Le record légendaire de notre boss de 920 victoires et 0 défaite a été brisé !
Dialogue: 0,0:09:09.14,0:09:11.73,Main,,0,0,0,,Incroyablement, la victoire revient...
Dialogue: 0,0:09:18.41,0:09:25.68,Flashbacks,,0,0,0,,Je ne te... laisserai pas prendre... un seul membre de mon équipage... même si ça me coûte la vie !
Dialogue: 0,0:09:25.68,0:09:30.55,Main,,0,0,0,,...à Chapeau de Paille Luffy !
Dialogue: 0,0:09:35.49,0:09:37.74,Main,,0,0,0,,Notre boss... a perdu...
Dialogue: 0,0:09:37.74,0:09:40.00,Main,,0,0,0,,Pirates de Foxy contre...
Dialogue: 0,0:09:40.00,0:09:44.05,Main,,0,0,0,,Hé ! Ne restez pas là ! Le boss a besoin de notre aide !
Dialogue: 0,0:09:44.39,0:09:46.02,Main,,0,0,0,,D'accord ! J'y vais !
Dialogue: 0,0:09:46.02,0:09:47.50,Main,,0,0,0,,...le Chapeaux de Paille !
Dialogue: 0,0:09:47.50,0:09:48.81,Main,,0,0,0,,J'y vais ! Bougez !
Dialogue: 0,0:09:48.81,0:09:49.86,Main,,0,0,0,,J'y vais aussi !
Dialogue: 0,0:09:49.86,0:09:58.23,Main,,0,0,0,,Ce jeu Davy Back Fight à trois pièces et règles orthodoxes est maintenant terminé !
Dialogue: 0,0:10:02.95,0:10:05.47,Main,,0,0,0,,Boss !
Dialogue: 0,0:10:07.03,0:10:09.73,Main,,0,0,0,,Boss !
Dialogue: 0,0:10:16.51,0:10:19.37,Main,,0,0,0,,Pff, aurais-tu pu être plus imprudent ?!
Dialogue: 0,0:10:19.77,0:10:21.04,Main,,0,0,0,,Prends ça ! Et ça !
Dialogue: 0,0:10:21.04,0:10:24.81,Main,,0,0,0,,Arrête de le piquer autant ! Il est gravement blessé, espèce d'idiot !
Dialogue: 0,0:10:24.81,0:10:26.64,Main,,0,0,0,,Il nous a inquiétés tout le temps...
Dialogue: 0,0:10:26.64,0:10:28.33,Main,,0,0,0,,La puissance Afro mon œil.
Dialogue: 0,0:10:28.97,0:10:32.34,Main,,0,0,0,,Les Afro sont vraiment puissants, Nami-san !
Dialogue: 0,0:10:33.89,0:10:35.71,Main,,0,0,0,,Oh ! Il est conscient !
Dialogue: 0,0:10:36.51,0:10:38.42,Main,,0,0,0,,H-Hein ?!
Dialogue: 0,0:10:38.85,0:10:40.62,Main,,0,0,0,,Le jeu ! Comment le jeu s'est-il terminé ?!
Dialogue: 0,0:10:41.15,0:10:44.11,Main,,0,0,0,,Je croyais avoir gagné... C'était juste un rêve ?!
Dialogue: 0,0:10:44.45,0:10:46.53,Main,,0,0,0,,Ne t'inquiète pas. Tu as gagné.
Dialogue: 0,0:10:50.65,0:10:51.93,Main,,0,0,0,,Quel soulagement...
Dialogue: 0,0:10:53.87,0:10:56.59,Main,,0,0,0,,Je n'ai jamais été inquiet le moins du monde !
Dialogue: 0,0:10:56.95,0:10:58.22,Main,,0,0,0,,Menteur.
Dialogue: 0,0:10:58.22,0:11:03.33,Main,,0,0,0,,Maintenant que j'y pense, je n'ai aucune raison d'être un pirate pour un autre navire.
Dialogue: 0,0:11:03.85,0:11:04.73,Main,,0,0,0,,Boss !
Dialogue: 0,0:11:04.73,0:11:06.23,Main,,0,0,0,,Tu ne devrais pas encore bouger !
Dialogue: 0,0:11:06.61,0:11:08.14,Main,,0,0,0,,Hé Chapeau de Paille !
Dialogue: 0,0:11:08.14,0:11:13.00,Main,,0,0,0,,Comment oses-tu ternir ma légendaire série d'invincibilité ?!
Dialogue: 0,0:11:13.00,0:11:14.15,Main,,0,0,0,,Boss !
Dialogue: 0,0:11:15.81,0:11:17.65,Main,,0,0,0,,Tape-m'en cinq, frérot !
Dialogue: 0,0:11:18.33,0:11:19.89,Main,,0,0,0,,Boss !
Dialogue: 0,0:11:20.25,0:11:22.13,Main,,0,0,0,,D'accord, Boss !
Dialogue: 0,0:11:25.91,0:11:27.75,Main,,0,0,0,,{\fad(150,150)}Spiteful Shoulder Throw !
Dialogue: 0,0:11:28.89,0:11:30.01,Main,,0,0,0,,Boss !
Dialogue: 0,0:11:30.57,0:11:31.91,Main,,0,0,0,,Es-tu si stupide ?
Dialogue: 0,0:11:32.83,0:11:33.97,Main,,0,0,0,,As-tu oublié les règles ?
Dialogue: 0,0:11:34.57,0:11:37.12,Main,,0,0,0,,Choisis déjà tes 500 personnes !
Dialogue: 0,0:11:37.12,0:11:40.23,Main,,0,0,0,,Oui ! L'échange final nous attend !
Dialogue: 0,0:11:40.65,0:11:42.02,Main,,0,0,0,,Donne-nous ton drapeau pirate !
Dialogue: 0,0:11:42.02,0:11:43.69,Main,,0,0,0,,Quoi ?!
Dialogue: 0,0:11:44.11,0:11:48.81,Main,,0,0,0,,Tu ne peux pas être sérieux ! Tu nous dépouillerais de notre fierté comme ça ?!
Dialogue: 0,0:11:48.81,0:11:52.91,Main,,0,0,0,,Je n'ai pas besoin de votre voile. Vous en avez besoin pour voyager, après tout.
Dialogue: 0,0:11:53.97,0:11:55.79,Main,,0,0,0,,Oh ! Il est si miséricordieux !
Dialogue: 0,0:11:55.79,0:11:58.55,Main,,0,0,0,,Mais notre symbole est dessus !
Dialogue: 0,0:11:58.55,0:12:00.63,Main,,0,0,0,,Comment voulez-vous qu'on utilise la voile ?!
Dialogue: 0,0:12:01.21,0:12:04.41,Main,,0,0,0,,On n'a pas besoin de votre pitié ! Prenez juste ce qui est à vous !
Dialogue: 0,0:12:05.09,0:12:05.78,Main,,0,0,0,,Très bien.
Dialogue: 0,0:12:06.19,0:12:11.70,Main,,0,0,0,,Puisque votre marque est tout ce dont nous avons besoin, je vais en dessiner une nouvelle par-dessus pour vous.
Dialogue: 0,0:12:12.19,0:12:14.11,Main,,0,0,0,,Comme ça, vous pourrez garder votre voile.
Dialogue: 0,0:12:14.99,0:12:18.21,Main,,0,0,0,,Chapeau de Paille... Vous êtes un tel...!
Dialogue: 0,0:12:17.11,0:12:22.09,Note,,0,0,0,,Voile : Renard
Dialogue: 0,0:12:18.27,0:12:19.13,Main,,0,0,0,,Voilà !
Dialogue: 0,0:12:20.45,0:12:22.11,Main,,0,0,0,,C'est nul...!
Dialogue: 0,0:12:22.59,0:12:24.80,Main,,0,0,0,,Wow, ils sont vraiment reconnaissants !
Dialogue: 0,0:12:24.80,0:12:25.91,Main,,0,0,0,,Non, on ne l'est pas !
Dialogue: 0,0:12:26.55,0:12:28.71,Main,,0,0,0,,Hé ! Chapeau de Paille !
Dialogue: 0,0:12:29.43,0:12:32.25,Main,,0,0,0,,Je vous aurai pour ça !
Dialogue: 0,0:12:33.11,0:12:35.21,Main,,0,0,0,,Ils vont arrêter d'être des comédiens un jour ?
Dialogue: 0,0:12:41.39,0:12:45.33,Main,,0,0,0,,Allons, allons. Je ne monterai plus jamais sur des échasses.
Dialogue: 0,0:12:45.33,0:12:49.33,Main,,0,0,0,,Nous pourrons suivre le village ensemble maintenant, peu importe le nombre d'années que ça prendra.
Dialogue: 0,0:12:52.09,0:12:53.41,Main,,0,0,0,,Vous, les gars...!
Dialogue: 0,0:12:58.41,0:12:59.77,Main,,0,0,0,,Je suis allé leur botter le cul !
Dialogue: 0,0:13:04.77,0:13:06.51,Main,,0,0,0,,Tu es vraiment blessé...
Dialogue: 0,0:13:07.89,0:13:09.21,Main,,0,0,0,,Ce n'est rien de nouveau.
Dialogue: 0,0:13:11.61,0:13:12.95,Main,,0,0,0,,Merci...
Dialogue: 0,0:13:18.09,0:13:21.21,Main,,0,0,0,,Ah, c'est pour ça que tu as accepté leur défi.
Dialogue: 0,0:13:21.77,0:13:24.20,Main,,0,0,0,,Pas que tu n'aurais pas fait autrement, cela dit.
Dialogue: 0,0:13:24.20,0:13:25.77,Main,,0,0,0,,Mec, tu es impoli !
Dialogue: 0,0:13:33.21,0:13:34.83,Main,,0,0,0,,Qu-Qu'est-ce que c'est que ça ?!
Dialogue: 0,0:13:37.39,0:13:38.87,Main,,0,0,0,,Aïe !
Dialogue: 0,0:13:40.73,0:13:43.79,Main,,0,0,0,,Je suis le champion ! Yo !
Dialogue: 0,0:13:44.37,0:13:45.71,Main,,0,0,0,,Pas un autre cinglé...
Dialogue: 0,0:13:46.03,0:13:47.61,Main,,0,0,0,,Champion de quoi ?!
Dialogue: 0,0:13:47.61,0:13:50.74,Main,,0,0,0,,Je suis le champion du monde de creusage de trous !
Dialogue: 0,0:13:50.74,0:13:54.04,Main,,0,0,0,,Je suis en train de défier mon propre record en ce moment même !
Dialogue: 0,0:13:54.30,0:13:58.84,Main,,0,0,0,,Quel genre de défi vous fait démolir la maison du vieux aux échasses ?!
Dialogue: 0,0:14:02.30,0:14:05.99,Main,,0,0,0,,"Le vieux aux échasses"...?
Dialogue: 0,0:14:08.12,0:14:09.80,Flashbacks,,0,0,0,,Tu peux te débrouiller pendant mon absence ?
Dialogue: 0,0:14:09.80,0:14:14.96,Flashbacks,,0,0,0,,Bien sûr. Mais assure-toi de revenir en champion !
Dialogue: 0,0:14:14.96,0:14:17.41,Flashbacks,,0,0,0,,Mais bien sûr que je le ferai !
Dialogue: 0,0:14:17.92,0:14:19.02,Flashbacks,,0,0,0,,Je le promets !
Dialogue: 0,0:14:20.44,0:14:23.31,Main,,0,0,0,,Serait-ce ? Tu es...?!
Dialogue: 0,0:14:23.94,0:14:25.06,Main,,0,0,0,,C'est moi !
Dialogue: 0,0:14:26.08,0:14:27.38,Main,,0,0,0,,Papi !
Dialogue: 0,0:14:26.80,0:14:28.45,Main,,0,0,0,,Littonto !
Dialogue: 0,0:14:28.45,0:14:32.28,Main,,0,0,0,,Tu m'as manqué ! Tu m'as tellement manqué !
Dialogue: 0,0:14:32.70,0:14:36.89,Main,,0,0,0,,Tu as tellement grandi depuis la dernière fois que je t'ai vu...!
Dialogue: 0,0:14:38.34,0:14:40.50,Main,,0,0,0,,Je suis désolé de t'avoir inquiété...
Dialogue: 0,0:14:41.92,0:14:43.68,Main,,0,0,0,,C'est ton petit-fils ?
Dialogue: 0,0:14:45.00,0:14:48.72,Main,,0,0,0,,Mon grand-père m'a tellement manqué que cette dévotion m'a mené au creusage de trous !
Dialogue: 0,0:14:48.72,0:14:55.16,Main,,0,0,0,,Et avant que je ne m'en rende compte, devenir le plus grand creuseur du monde était devenu mon plus grand objectif dans la vie...
Dialogue: 0,0:14:58.62,0:15:00.51,Main,,0,0,0,,C'est pas génial, le vieux ?!
Dialogue: 0,0:15:00.51,0:15:03.35,Main,,0,0,0,,Oui. Je ne sais pas comment vous remercier...
Dialogue: 0,0:15:04.82,0:15:08.28,Main,,0,0,0,,Je n'oublierai jamais ce que vous avez fait pour nous !
Dialogue: 0,0:15:09.70,0:15:11.44,Main,,0,0,0,,Merci !
Dialogue: 0,0:15:11.44,0:15:14.74,Main,,0,0,0,,Faites attention sur le chemin du retour !
Dialogue: 0,0:15:14.74,0:15:18.98,Main,,0,0,0,,Vous aussi ! Je prie pour que votre voyage se passe bien !
Dialogue: 0,0:15:21.45,0:15:24.50,Main,,0,0,0,,Très bien, les gars !
Dialogue: 0,0:15:24.96,0:15:28.57,Main,,0,0,0,,Allons trouver un charpentier naval !
Dialogue: 0,0:15:28.92,0:15:30.47,Main,,0,0,0,,Ouais !

